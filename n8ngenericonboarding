        "jsCode": "const inputs = $input.all();\nconst originalData = $input.first().json;\n\nconst results = {};\nconst errors = [];\nconst retryableSystems = [];\n\ninputs.forEach(item => {\n  const data = item.json;\n  if (data && data.system) {\n    results[data.system] = data;\n    if (!data.success) {\n      errors.push({\n        system: data.system,\n        error: data.error,\n        error_code: data.error_code,\n        retryable: data.retryable\n      });\n      if (data.retryable) {\n        retryableSystems.push(data.system);\n      }\n    }\n  }\n});\n\nconst criticalSystems = ['hr', 'identity', 'email'];\nconst criticalFailures = errors.filter(e => criticalSystems.includes(e.system));\nconst onboardingComplete = criticalFailures.length === 0;\n\nconst systemsProvisioned = Object.keys(results).filter(k => results[k].success);\nconst systemsFailed = errors.map(e => e.system);\n\nreturn [{\n  json: {\n    ...originalData,\n    provisioning_results: results,\n    summary: {\n      total_systems: Object.keys(results).length,\n      successful: systemsProvisioned.length,\n      failed: systemsFailed.length,\n      success_rate: `${systemsProvisioned.length}/${Object.keys(results).length}`,\n      all_success: errors.length === 0,\n      partial_success: errors.length > 0 && systemsProvisioned.length > 0,\n      critical_failures: criticalFailures.length,\n      onboarding_complete: onboardingComplete,\n      failed_systems: systemsFailed,\n      retryable_systems: retryableSystems,\n      requires_manual_fix: criticalFailures.length > 0 && !retryableSystems.some(s => criticalSystems.includes(s))\n    },\n    errors: errors,\n    _aggregation_time: new Date().toISOString()\n  }\n}];"
      },
